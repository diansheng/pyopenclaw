# PyOpenClaw Configuration
# Copy this file to .env and fill in your values

# LLM Provider API Keys
# ---------------------
# OpenAI (Default)
OPENAI_API_KEY=sk-placeholder-key

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-placeholder-key

# Google Gemini
# GEMINI_API_KEY=placeholder-key

# MiniMax (or Coding Plan API Key)
# MINIMAX_API_KEY=placeholder-key
# MINIMAX_GROUP_ID=placeholder-group-id

# Channel Configuration
# ---------------------
# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Slack
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_APP_TOKEN=xapp-your-token

# Application Settings
# --------------------
# LOG_LEVEL=INFO
# ALLOWED_PATHS=~/workspace
